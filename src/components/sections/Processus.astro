---
const etapes = [
  {
    number: "01",
    title: "Conversation confidentielle initiale",
    description:
      "Un échange simple et sans pression pour comprendre votre situation, vos objectifs et voir si notre approche vous convient.",
    detail: "30–60 min",
  },
  {
    number: "02",
    title: "Évaluation respectueuse de votre entreprise",
    description:
      "Nous prenons le temps d'analyser votre entreprise avec rigueur et discrétion — financièrement, opérationnellement, humainement.",
    detail: "2–4 semaines",
  },
  {
    number: "03",
    title: "Proposition structurée et juste",
    description:
      "Nous vous soumettons une offre claire, transparente et équitable. Vous avez tout le temps pour réfléchir, consulter et décider.",
    detail: "À votre rythme",
  },
  {
    number: "04",
    title: "Transition humaine et planifiée",
    description:
      "Ensemble, nous planifions chaque étape du transfert pour assurer la continuité de vos opérations, de votre équipe et de votre héritage.",
    detail: "3–12 mois",
  },
];
---

<section id="processus" class="relative py-32 lg:py-40 bg-[#0C0C0C]">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#D4AF37]/15 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <!-- Header -->
    <div class="text-center mb-24 reveal-proc">
      <span class="inline-block font-sans text-[10px] tracking-[0.4em] uppercase text-[#D4AF37] mb-6">
        Notre processus
      </span>
      <h2 class="font-serif text-[clamp(2rem,5vw,3.5rem)] font-bold text-[#E8E8E8] leading-tight">
        Simple. Transparent.<br />
        <em class="not-italic text-[#D4AF37]">Planifié pour vous.</em>
      </h2>
    </div>

    <!-- Timeline desktop -->
    <div class="hidden lg:block">
      <!-- Connecting line -->
      <div class="relative flex items-start justify-between gap-0 mb-0">
        <!-- Background line -->
        <div class="absolute top-8 left-[calc(12.5%)] right-[calc(12.5%)] h-px bg-[#1E1E1E]"></div>
        <!-- Gold progress line (animated) -->
        <div
          class="proc-line absolute top-8 left-[calc(12.5%)] h-px bg-gradient-to-r from-[#D4AF37] to-[#D4AF37]/40 origin-left"
          style="width: 0; right: auto; transition: width 1.4s cubic-bezier(0.22, 1, 0.36, 1) 0.3s"
        ></div>

        {
          etapes.map((etape, i) => (
            <div
              class="reveal-proc relative flex-1 flex flex-col items-center text-center px-6"
              style={`transition-delay: ${i * 0.15}s`}
            >
              <!-- Circle -->
              <div class="relative z-10 w-16 h-16 rounded-full border border-[#1E1E1E] bg-[#0C0C0C] flex items-center justify-center mb-8 group-hover:border-[#D4AF37]/40 transition-colors duration-300">
                <span class="font-sans text-xs tracking-[0.2em] text-[#D4AF37]">
                  {etape.number}
                </span>
              </div>

              <!-- Detail badge -->
              <span class="inline-block font-sans text-[9px] tracking-[0.25em] uppercase text-[#3A3A3A] border border-[#1A1A1A] px-3 py-1 mb-5">
                {etape.detail}
              </span>

              <h3 class="font-serif text-base font-semibold text-[#CCCCCC] mb-3 leading-snug">
                {etape.title}
              </h3>
              <p class="font-sans text-sm text-[#555555] leading-relaxed max-w-[220px]">
                {etape.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Timeline mobile/tablet -->
    <div class="lg:hidden flex flex-col gap-0">
      {
        etapes.map((etape, i) => (
          <div
            class="reveal-proc relative flex gap-6 pb-10"
            style={`transition-delay: ${i * 0.12}s`}
          >
            <!-- Left: number + vertical line -->
            <div class="flex flex-col items-center">
              <div class="w-12 h-12 flex-shrink-0 rounded-full border border-[#1E1E1E] bg-[#0C0C0C] flex items-center justify-center">
                <span class="font-sans text-[10px] tracking-[0.15em] text-[#D4AF37]">
                  {etape.number}
                </span>
              </div>
              {i < etapes.length - 1 && (
                <div class="flex-1 w-px bg-gradient-to-b from-[#D4AF37]/20 to-transparent mt-3" />
              )}
            </div>

            <!-- Right: content -->
            <div class="pt-2 pb-4">
              <span class="inline-block font-sans text-[9px] tracking-[0.25em] uppercase text-[#3A3A3A] border border-[#1A1A1A] px-2.5 py-1 mb-4">
                {etape.detail}
              </span>
              <h3 class="font-serif text-base font-semibold text-[#CCCCCC] mb-2 leading-snug">
                {etape.title}
              </h3>
              <p class="font-sans text-sm text-[#555555] leading-relaxed">
                {etape.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");

          // Animate the connecting line on desktop
          const line = document.querySelector(".proc-line") as HTMLElement;
          if (line) {
            line.style.width = "75%";
          }

          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll("#processus .reveal-proc").forEach((el) => {
    observer.observe(el);
  });
</script>

<style>
  .reveal-proc {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

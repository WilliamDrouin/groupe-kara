---
import { Image } from "astro:assets";
import keyImg from "@/assets/images/yahdi-yasya-cTeK-DLbKk4-unsplash.jpg";

const etapes = [
  {
    number: "01",
    title: "Conversation confidentielle initiale",
    description:
      "Un échange simple et sans pression pour comprendre votre situation, vos objectifs et voir si notre approche vous convient.",
    detail: "30–60 min",
  },
  {
    number: "02",
    title: "Évaluation respectueuse de votre entreprise",
    description:
      "Nous prenons le temps d'analyser votre entreprise avec rigueur et discrétion — financièrement, opérationnellement, humainement.",
    detail: "2–4 semaines",
  },
  {
    number: "03",
    title: "Proposition structurée et juste",
    description:
      "Nous vous soumettons une offre claire, transparente et équitable. Vous avez tout le temps pour réfléchir, consulter et décider.",
    detail: "À votre rythme",
  },
  {
    number: "04",
    title: "Transition humaine et planifiée",
    description:
      "Ensemble, nous planifions chaque étape du transfert pour assurer la continuité de vos opérations, de votre équipe et de votre héritage.",
    detail: "3–12 mois",
  },
];
---

<section id="processus" class="relative py-32 lg:py-40 bg-[#0C0C0C]">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#D4AF37]/15 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <!-- Header with key image accent -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-24 items-center" data-reveal>
      <div class="lg:col-span-8 text-center lg:text-left">
        <span class="inline-block font-sans text-[10px] tracking-[0.4em] uppercase text-[#D4AF37] mb-6">
          Notre processus
        </span>
        <h2 class="font-serif text-[clamp(2rem,5vw,3.5rem)] font-bold text-[#E8E8E8] leading-tight">
          Simple. Transparent.<br />
          <em class="not-italic text-[#D4AF37]">Planifié pour vous.</em>
        </h2>
        <p class="mt-6 font-sans text-sm text-[#A0A0A0] tracking-wide max-w-md mx-auto lg:mx-0 leading-relaxed">
          De la première conversation au transfert final — chaque étape est conçue pour préserver ce que vous avez bâti.
        </p>
      </div>
      <div class="lg:col-span-4">
        <div class="relative overflow-hidden border border-[#1A1A1A] max-w-[280px] mx-auto lg:ml-auto lg:mr-0">
          <Image
            src={keyImg}
            alt="Transmission d'une clé entre deux mains — symbolique du transfert d'entreprise"
            loading="lazy"
            class="w-full h-[320px] md:h-[380px] object-cover opacity-90"
            widths={[320, 480, 640]}
            sizes="(max-width: 1024px) 280px, 320px"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#0C0C0C]/85"></div>
          <div class="absolute bottom-4 left-4 right-4">
            <span class="block font-sans text-[9px] tracking-[0.3em] uppercase text-[#D4AF37]">
              Transition planifiée
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Desktop timeline -->
    <div class="hidden lg:block">
      <div class="relative flex items-start justify-between" data-reveal-group>
        <!-- Background track -->
        <div class="absolute top-8 left-[calc(12.5%)] right-[calc(12.5%)] h-px bg-[#1E1E1E]"></div>
        <!-- Animated gold line (Motion grows this) -->
        <div class="proc-line absolute top-8 left-[calc(12.5%)] h-px bg-gradient-to-r from-[#D4AF37] to-[#D4AF37]/40 origin-left" style="width: 0"></div>

        {
          etapes.map((etape) => (
            <div class="relative flex-1 flex flex-col items-center text-center px-6" data-reveal-item>
              <div class="relative z-10 w-16 h-16 rounded-full border border-[#1E1E1E] bg-[#0C0C0C] flex items-center justify-center mb-8">
                <span class="font-sans text-xs tracking-[0.2em] text-[#D4AF37]">
                  {etape.number}
                </span>
              </div>
              <span class="inline-block font-sans text-[9px] tracking-[0.25em] uppercase text-[#6E6E6E] border border-[#1A1A1A] px-3 py-1 mb-5">
                {etape.detail}
              </span>
              <h3 class="font-serif text-base font-semibold text-[#CCCCCC] mb-3 leading-snug">
                {etape.title}
              </h3>
              <p class="font-sans text-sm text-[#8A8A8A] leading-relaxed max-w-[220px]">
                {etape.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Mobile / tablet timeline -->
    <div class="lg:hidden flex flex-col gap-0" data-reveal-group>
      {
        etapes.map((etape, i) => (
          <div class="relative flex gap-6 pb-10" data-reveal-item>
            <div class="flex flex-col items-center">
              <div class="w-12 h-12 flex-shrink-0 rounded-full border border-[#1E1E1E] bg-[#0C0C0C] flex items-center justify-center">
                <span class="font-sans text-[10px] tracking-[0.15em] text-[#D4AF37]">
                  {etape.number}
                </span>
              </div>
              {i < etapes.length - 1 && (
                <div class="flex-1 w-px bg-gradient-to-b from-[#D4AF37]/20 to-transparent mt-3" />
              )}
            </div>
            <div class="pt-2 pb-4">
              <span class="inline-block font-sans text-[9px] tracking-[0.25em] uppercase text-[#6E6E6E] border border-[#1A1A1A] px-2.5 py-1 mb-4">
                {etape.detail}
              </span>
              <h3 class="font-serif text-base font-semibold text-[#CCCCCC] mb-2 leading-snug">
                {etape.title}
              </h3>
              <p class="font-sans text-sm text-[#8A8A8A] leading-relaxed">
                {etape.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

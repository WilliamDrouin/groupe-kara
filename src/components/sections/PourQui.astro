---
const criteres = [
  {
    number: "01",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="3" y="10" width="18" height="11" stroke="#D4AF37" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M3 10L12 3L21 10" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <rect x="9" y="15" width="6" height="6" stroke="#D4AF37" stroke-width="1.5"/>
    </svg>`,
    title: "Entreprise locale bien établie",
    description:
      "Votre entreprise est active depuis plusieurs années avec des revenus stables, une équipe en place et une réputation solide dans votre secteur.",
  },
  {
    number: "02",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="9" cy="7" r="3" stroke="#D4AF37" stroke-width="1.5"/>
      <circle cx="17" cy="9" r="2.5" stroke="#D4AF37" stroke-width="1.5"/>
      <path d="M3 20C3 17.239 5.686 15 9 15C10.178 15 11.274 15.316 12.2 15.858" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M14 20C14 18.343 15.567 17 17.5 17C19.433 17 21 18.343 21 20" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    title: "Clientèle fidèle et historique stable",
    description:
      "Vous avez bâti une base de clients qui revient année après année. Votre historique financier reflète une entreprise saine et prévisible.",
  },
  {
    number: "03",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M5 12H19" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M13 6L19 12L13 18" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M5 6V18" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
    </svg>`,
    title: "Une transition en vue",
    description:
      "Que ce soit la retraite, un changement de cap ou simplement le bon moment — vous pensez sérieusement à vendre ou à céder votre entreprise.",
  },
  {
    number: "04",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M12 2L14.4 9H21.6L15.6 13.4L18 20L12 15.6L6 20L8.4 13.4L2.4 9H9.6L12 2Z" stroke="#D4AF37" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>`,
    title: "Une suite digne de votre œuvre",
    description:
      "Vous avez construit quelque chose de solide. Vous voulez que ça continue — pour vos employés, vos clients, et votre propre tranquillité d'esprit.",
  },
];
---

<section id="apropos" class="relative py-32 lg:py-40 bg-[#0A0A0A]">
  <!-- Subtle top separator -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-20 bg-gradient-to-b from-[#D4AF37] to-transparent opacity-20">
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <!-- Section header -->
    <div class="text-center mb-20 reveal">
      <span
        class="inline-block font-sans text-[10px] tracking-[0.4em] uppercase text-[#D4AF37] mb-6"
      >
        Critères d'acquisition
      </span>

      <h2
        class="font-serif text-[clamp(2rem,5vw,3.5rem)] font-bold text-[#E8E8E8] leading-tight max-w-2xl mx-auto"
      >
        Vous êtes propriétaire<br />
        <em class="not-italic text-[#D4AF37]">d'une PME rentable?</em>
      </h2>

      <p class="mt-6 font-sans text-sm text-[#555555] tracking-wide max-w-md mx-auto leading-relaxed">
        Si vous vous reconnaissez dans les critères suivants, nous avons
        peut-être une conversation à avoir.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
      {
        criteres.map((item, i) => (
          <div
            class="critere-card reveal group relative bg-[#0F0F0F] border border-[#1A1A1A] p-8 lg:p-10 transition-all duration-500 hover:border-[#D4AF37]/30 hover:bg-[#111111] cursor-default"
            style={`animation-delay: ${i * 0.12}s`}
          >
            <!-- Decorative number -->
            <span class="absolute top-6 right-8 font-serif text-5xl font-bold text-[#D4AF37]/[0.05] select-none transition-all duration-500 group-hover:text-[#D4AF37]/[0.1]">
              {item.number}
            </span>

            <!-- Gold top accent line -->
            <div class="absolute top-0 left-0 h-px w-0 bg-[#D4AF37] transition-all duration-700 group-hover:w-full" />

            <!-- Icon -->
            <div class="mb-6" set:html={item.icon} />

            <!-- Content -->
            <h3 class="font-serif text-lg font-semibold text-[#E8E8E8] mb-3 leading-snug">
              {item.title}
            </h3>
            <p class="font-sans text-sm text-[#666666] leading-relaxed">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Bottom note -->
    <div class="text-center mt-16 reveal">
      <p class="font-sans text-xs text-[#3A3A3A] tracking-widest uppercase">
        Une seule conversation suffit pour savoir si votre situation nous correspond.
      </p>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll("#apropos .reveal").forEach((el) => {
    observer.observe(el);
  });
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger cards via their inline animation-delay */
  .critere-card.reveal {
    transition-delay: var(--delay, 0s);
  }

  .critere-card:nth-child(1) { --delay: 0s; }
  .critere-card:nth-child(2) { --delay: 0.1s; }
  .critere-card:nth-child(3) { --delay: 0.2s; }
  .critere-card:nth-child(4) { --delay: 0.3s; }
</style>

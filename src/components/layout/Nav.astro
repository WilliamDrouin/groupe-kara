---
import Button from "@/components/ui/Button.astro";
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <nav class="max-w-7xl mx-auto px-6 lg:px-12 flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="#" class="group">
      <span
        class="font-serif text-base tracking-[0.25em] uppercase text-[#D4AF37] font-semibold transition-opacity duration-300 group-hover:opacity-80"
      >
        Groupe Kara
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-10">
      {
        [
          { label: "À propos", href: "#apropos" },
          { label: "Critères", href: "#criteres" },
          { label: "Processus", href: "#processus" },
          { label: "Contact", href: "#contact" },
        ].map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="font-sans text-xs tracking-widest uppercase text-[#888888] hover:text-[#D4AF37] transition-colors duration-300"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA -->
    <div class="hidden md:block">
      <Button href="#contact" variant="outline" size="sm">
        Conversation confidentielle
      </Button>
    </div>

    <!-- Mobile burger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Menu"
    >
      <span class="block w-6 h-px bg-[#D4AF37] transition-all duration-300"></span>
      <span class="block w-4 h-px bg-[#D4AF37] transition-all duration-300"></span>
      <span class="block w-6 h-px bg-[#D4AF37] transition-all duration-300"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-[#1A1A1A] bg-[#0A0A0A]"
  >
    <ul class="flex flex-col px-6 py-6 gap-6">
      {
        [
          { label: "À propos", href: "#apropos" },
          { label: "Critères", href: "#criteres" },
          { label: "Processus", href: "#processus" },
          { label: "Contact", href: "#contact" },
        ].map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="font-sans text-sm tracking-widest uppercase text-[#888888] hover:text-[#D4AF37] transition-colors duration-300"
            >
              {label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <Button href="#contact" variant="outline" size="sm" class="w-full justify-center">
          Conversation confidentielle
        </Button>
      </li>
    </ul>
  </div>
</header>

<script>
  const nav = document.getElementById("nav");
  const mobileBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  // Scroll: transparent → solid black
  window.addEventListener("scroll", () => {
    if (window.scrollY > 60) {
      nav?.classList.add("nav-scrolled");
    } else {
      nav?.classList.remove("nav-scrolled");
    }
  });

  // Mobile toggle
  mobileBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
    });
  });
</script>

<style>
  .nav-scrolled {
    background-color: rgba(10, 10, 10, 0.97);
    border-bottom: 1px solid rgba(212, 175, 55, 0.15);
    backdrop-filter: blur(12px);
  }
</style>

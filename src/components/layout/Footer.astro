---
---

<footer class="relative bg-[#080808] border-t border-[#141414] overflow-hidden">
  <!-- Top accent line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#D4AF37]/20 to-transparent"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 py-16">
    <!-- Main row -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-10 mb-12">
      <!-- Logo + tagline -->
      <div>
        <a href="#" class="group mb-3 inline-block">
          <span class="font-serif text-sm tracking-[0.25em] uppercase text-[#D4AF37] font-semibold transition-opacity duration-300 group-hover:opacity-80">
            Groupe Kara
          </span>
        </a>
        <p class="font-sans text-xs tracking-widest text-[#8A8A8A] uppercase">
          Acquérir. Structurer. Faire croître.
        </p>
      </div>

      <!-- Nav links -->
      <nav aria-label="Navigation pied de page">
        <ul class="flex flex-wrap gap-x-8 gap-y-3">
          {
            [
              { label: "À propos", href: "#apropos" },
              { label: "Critères", href: "#criteres" },
              { label: "Processus", href: "#processus" },
              { label: "Contact", href: "#contact" },
            ].map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="font-sans text-[10px] tracking-widest uppercase text-[#8A8A8A] hover:text-[#D4AF37] transition-colors duration-300"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-[#141414] mb-8"></div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex flex-col gap-1">
        <p class="font-sans text-[10px] text-[#8A8A8A] tracking-wide">
          Québec, Canada &nbsp;·&nbsp;
          <a
            href="mailto:info@groupekara.ca"
            class="hover:text-[#D4AF37] transition-colors duration-300"
          >
            info@groupekara.ca
          </a>
        </p>
        <p class="font-sans text-[10px] text-[#6E6E6E] tracking-wide">
          © {new Date().getFullYear()} Groupe Kara. Tous droits réservés.
        </p>
      </div>

      <!-- Credit -->
      <p class="font-sans text-[9px] tracking-widest text-[#6E6E6E] uppercase">
        Conçu par <span class="text-[#8A8A8A]">PowerAi</span>
      </p>
    </div>
  </div>
</footer>

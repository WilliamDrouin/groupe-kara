---
import Nav from "@/components/layout/Nav.astro";
import Footer from "@/components/layout/Footer.astro";
import { getImage } from "astro:assets";
import ogImageSrc from "@/assets/images/photoslogan-hero.jpg";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Groupe Kara — Acquérir. Structurer. Faire croître.",
  description = "Groupe Kara accompagne les propriétaires de PME québécois dans la planification et la réalisation de leur transition d'entreprise.",
} = Astro.props;

const ogImage = await getImage({ src: ogImageSrc, width: 1200, height: 630, format: "jpg" });
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage.src, Astro.site ?? Astro.url).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-[#0A0A0A] text-[#E8E8E8] overflow-x-hidden">
    <!-- Scroll progress bar -->
    <div
      id="scroll-progress"
      class="fixed top-0 left-0 right-0 h-[2px] bg-[#D4AF37] origin-left z-[200]"
      style="transform: scaleX(0)"
      aria-hidden="true"
    >
    </div>

    <Nav />
    <slot />
    <Footer />

    <script>
      import { initAnimations } from "@/lib/animations";
      initAnimations();
    </script>
  </body>
</html>
